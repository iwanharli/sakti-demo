# DATABASE 1 - PRIMARY
DB_PRIMARY_HOST=localhost
DB_PRIMARY_PORT=5432
DB_PRIMARY_USER=postgres
DB_PRIMARY_PASSWORD=
DB_PRIMARY_NAME=sakti_primary
DB_PRIMARY_URL=postgresql://postgres:@localhost:5432/sakti_primary

# DATABASE 2 - SECONDARY/LOGS
DB_SECONDARY_HOST=localhost
DB_SECONDARY_PORT=5433
DB_SECONDARY_USER=postgres
DB_SECONDARY_PASSWORD=
DB_SECONDARY_NAME=sakti_logs
DB_SECONDARY_URL=postgresql://postgres:@localhost:5433/sakti_logs

# INFO:
# Jika Anda menggunakan variabel ini di sisi klien (Frontend Vite),
# Anda harus menambahkan prefix VITE_ (contoh: VITE_DB_PRIMARY_NAME).
# NAMUN, sangat disarankan untuk tidak menyimpan kredensial database langsung di Frontend 
# demi keamanan. Gunakan variabel ini di sisi Backend (Node.js/Server).
